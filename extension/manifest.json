{
    "manifest_version": 3,
    "name": "Auto GDPR Reject",
    "version": "1.1",
    "description": "Automatically rejects GDPR cookie consent pop-ups by clicking \"Reject All\" for you.",
    "icons": {
        "48": "images/icon-48.png",
        "96": "images/icon-96.png",
        "128": "images/icon-128.png",
        "256": "images/icon-256.png",
        "512": "images/icon-512.png"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_end",
            "all_frames": true
        }
    ]
}
